# voidbase configuration — copy to .env and fill in. .env is gitignored, so
# nothing here ever lands in a commit. db.conn.env_value() reads these from the
# environment first, then this file.

# --- Neon / Postgres (the shared store) -------------------------------------
# DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require
# DATABASE_URL_POOLED=postgres://USER:PASSWORD@HOST-pooler/DB?sslmode=require

# --- GPU box / SSH target (used by scripts/worker.py) -----------------------
# REQUIRED to run jobs. The worker SSHes the training command to this box; Neon
# creds never leave the dispatcher. There is NO hard-coded default for the host
# — it must be set here (or in the environment).
VOIDBASE_BOX_HOST=                 # e.g. 1.2.3.4 — the rented box's address
VOIDBASE_BOX_PORT=22               # SSH port
VOIDBASE_BOX_USER=root             # SSH user
VOIDBASE_BOX_REPO=/root/universe-lm   # research repo path on the box
VOIDBASE_BOX_PYTHON=/venv/main/bin/python   # python on the box
# Env exported before every training command. Keep TORCHDYNAMO_DISABLE=1 for
# sm_86 (RTX 3060) boxes — torch.compile crashes them mid-run.
VOIDBASE_BOX_ENV=TORCHDYNAMO_DISABLE=1

# --- Dataset cache (persistent, skip the ~15GB re-download) ------------------
# A dir ON THE BOX's persistent volume. When set, the worker exports HF_HOME and
# HF_DATASETS_CACHE so HuggingFace downloads the dataset once and reuses it on
# every later run. Leave blank to keep the box default (re-downloads each run).
VOIDBASE_DATASET_CACHE=/root/data-cache

# --- Heartbeat / health (worker + reaper) -----------------------------------
VOIDBASE_API_URL=http://127.0.0.1:8787   # where the worker POSTs box_heartbeat
VOIDBASE_HEARTBEAT_SECONDS=30            # worker ping interval during a run
VOIDBASE_BOX_HEARTBEAT_TIMEOUT=90        # reaper: box is "dark" past this age
VOIDBASE_REAPER_INTERVAL=60              # reaper: seconds between sweeps
